@model PdfFormDemo.Models.InspectionFormModel

@{
    ViewData["Title"] = "PDF Form Onayı";
}

<section class="portal-card">
    <h2 class="portal-card-title">PDF Form Onayı</h2>

    <form method="post" autocomplete="off">
        <div class="mb-4">
            <label class="form-label">Çalışan</label>

            <select asp-for="SelectedEmployeeId"
                    asp-items="ViewBag.Employees"
                    class="form-select">
                <option value="">Çalışan seçiniz</option>
            </select>

            <span asp-validation-for="SelectedEmployeeId"
                  class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="DeviceName" class="form-label">Cihaz Adı</label>
            <input asp-for="DeviceName"
                   type="text"
                   class="form-control"
                   placeholder="Cihaz adını giriniz" />
        </div>

        <div class="mb-4">
            <label asp-for="Temperature" class="form-label">Sıcaklık</label>
            <input asp-for="Temperature"
                   type="text"
                   class="form-control"
                   placeholder="Örn: 25°C" />
        </div>

        <div class="mb-4">
            <label asp-for="Result" class="form-label">Sonuç</label>
            <input asp-for="Result"
                   type="text"
                   class="form-control"
                   placeholder="Kontrol sonucunu giriniz" />
        </div>

        <div class="mb-4">
            <label class="form-label d-block">Kullanıma Uygun mu?</label>

            <div class="d-flex gap-4 flex-wrap">
                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           asp-for="IsUsable"
                           value="Evet" />

                    <label class="form-check-label">Evet</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           asp-for="IsUsable"
                           value="Hayır" />

                    <label class="form-check-label">Hayır</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 flex-wrap">
            <button type="submit" class="btn btn-primary">
                PDF Oluştur
            </button>

            <a class="btn-light-portal" asp-controller="Home" asp-action="Index">
                Vazgeç
            </a>
        </div>
    </form>
</section>
